<?xml version="1.0" encoding="UTF-8"?>
<!--
  Test-only Logback configuration.
  Logback loads this file in preference to logback-spring.xml during test runs,
  keeping test output minimal (console only, no OTel export).
-->
<configuration>
  <include resource="org/springframework/boot/logging/logback/defaults.xml"/>
  <include resource="org/springframework/boot/logging/logback/console-appender.xml"/>

  <logger name="com.fortytwotalents" level="DEBUG"/>

  <root level="INFO">
    <appender-ref ref="CONSOLE"/>
  </root>
</configuration>
